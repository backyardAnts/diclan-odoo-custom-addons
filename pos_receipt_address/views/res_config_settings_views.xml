<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_lbp_usd_rate" model="ir.ui.view">
        <field name="name">res.config.settings.form.inherit.lbp.usd.rate</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='pos_other_devices']" position="after">
                <div class="col-12 col-lg-6 o_setting_box">
                    <div class="o_setting_right_pane">
                        <label for="lbp_usd_rate"/>
                        <div class="text-muted">
                            Display-only USD conversion rate used on printed POS receipts.
                        </div>
                        <div class="content-group mt16">
                            <field name="lbp_usd_rate"/>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="pos_config_view_form_auto_invoice_receipt" model="ir.ui.view">
        <field name="name">pos.config.form.auto.invoice.receipt</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Receipt Invoice Number">
                    <field name="force_invoice_on_receipt"/>
                    <field name="default_receipt_partner_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>